# brapi-py — local credentials template
# Copy this file to .env and fill in your values.
# .env is git-ignored and will never be committed.

BRAPI_BASE_URL=https://brapi.example.org
BRAPI_TOKEN_ENDPOINT=https://brapi.example.org/token

# OAuth2 client-credentials flow
BRAPI_CLIENT_ID=your-client-id
BRAPI_CLIENT_SECRET=your-client-secret

# OAuth2 password flow (alternative to client credentials)
# BRAPI_USERNAME=your-username
# BRAPI_PASSWORD=your-password
